.venv/
__pycache__/
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.cache/

# Repo source lives in .py / .toml / .md — everything else is a session
# artifact (deck lists, parsed/hydrated JSON, Moxfield exports, Scryfall
# bulk data, collection CSV snapshots, scratch files). Re-introduce a
# specific tracked .json or .txt file with `git add -f` if that changes.
*.json
*.txt
*.idx.pkl

# proxy-printer's ASCII art catalog ships as package data. Each .txt is
# one card subtype's thumbnail icon; the renderer reads them at runtime.
# Reference images (.png/.jpg) used while authoring the catalog are
# session artifacts and should NOT be committed.
!mtg-utils/src/mtg_utils/data/card_art/*.txt
mtg-utils/src/mtg_utils/data/card_art/*.png
mtg-utils/src/mtg_utils/data/card_art/*.jpg
mtg-utils/src/mtg_utils/data/card_art/*.jpeg

# rules-lawyer's bundled digital-mechanics supplement ships as package data
# (downloaded comprehensive-rules*.txt stay ignored by the *.txt rule above).
!mtg-utils/src/mtg_utils/data/digital-rules.txt
# rules_lookup caches a pickled parse of the CR next to the (ignored) .txt.
*.parsed.pkl
# deck-forge's generated color-normalized format-staples list ships as package data.
!mtg-utils/src/mtg_utils/data/format-staples.txt

# deck-forge ships its built SPA so end-users run `uv run` with no Node
# toolchain (D11), plus the frontend manifest so devs can rebuild the UI.
# These override the global dist/ and *.json ignores above.
!deck-forge/frontend/package.json
!deck-forge/frontend/package-lock.json
!deck-forge/frontend/jsconfig.json
!deck-forge/frontend/dist/
!deck-forge/frontend/dist/**

# Committed test fixture: the real-card Scryfall + Card-IR snapshot (ADR-0027 /
# task #25). Lets the signal tests run real-card IR in CI with no sidecar/bulk/
# network. Refresh with `build-card-snapshot`. Overrides the global *.json ignore.
!tests/fixtures/card_snapshot.json
# Committed parse-completeness metric (ADR-0032), regenerated in the same gated
# `build-card-snapshot` step. The full-corpus numbers are the review drift-watch;
# the snapshot block is what test_parse_metrics recomputes offline in CI.
!tests/fixtures/parse_metrics.json

# Local scratch / session dirs (skill working output + Claude Code session state)
.deck-wizard-work/
.claude/

# Playwright MCP scratch (snapshots/screenshots from live UI testing)
.playwright-mcp/
