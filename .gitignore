.venv/
__pycache__/
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.cache/

# Repo source lives in .py / .toml / .md — everything else is a session
# artifact (deck lists, parsed/hydrated JSON, Moxfield exports, Scryfall
# bulk data, collection CSV snapshots, scratch files). Re-introduce a
# specific tracked .json or .txt file with `git add -f` if that changes.
*.json
*.txt
*.idx.pkl

# proxy-printer's ASCII art catalog ships as package data. Each .txt is
# one card subtype's thumbnail icon; the renderer reads them at runtime.
# Reference images (.png/.jpg) used while authoring the catalog are
# session artifacts and should NOT be committed.
!mtg-utils/src/mtg_utils/data/card_art/*.txt
mtg-utils/src/mtg_utils/data/card_art/*.png
mtg-utils/src/mtg_utils/data/card_art/*.jpg
mtg-utils/src/mtg_utils/data/card_art/*.jpeg
